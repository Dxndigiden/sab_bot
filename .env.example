# Токен бота
BOT_TOKEN=your_bot_token_here

# ID админов через запятую
ADMIN_IDS=123456789,987654321

# Лимит команд (0 = без лимита)
MAX_TEAMS=0

# ── База данных ───────────────────────────────────────────────────────────────
# Локально (python run.py) — USE_POSTGRES не указываем или false → SQLite
# USE_POSTGRES=false

# Через Docker (docker-compose up) — USE_POSTGRES=true выставляется автоматически
# Параметры Postgres (нужны и для Docker и для alembic migrate на Postgres)
POSTGRES_USER=sab
POSTGRES_PASSWORD=sab_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sab_tournament